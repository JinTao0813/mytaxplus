ENV=development
ALLOWED_ORIGINS=http://localhost:3000
GEMINI_API_KEY=
GOOGLE_AI_DOCUMENTS_API_KEY=

# Firebase Admin (verify ID tokens). Either set this to a service account JSON path:
# FIREBASE_CREDENTIALS_PATH=/absolute/path/to/service-account.json
# Or use Application Default Credentials:
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
FIREBASE_CREDENTIALS_PATH=

# Firebase session cookie (POST /api/v1/auth/session). Max age is capped at 14 days by Firebase.
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_MAX_AGE_SECONDS=432000
# Set true behind HTTPS in production
SESSION_COOKIE_SECURE=false
