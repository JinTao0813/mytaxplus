# Optional override. Leave empty to use same-origin Next.js route handlers.
NEXT_PUBLIC_API_URL=

# Firebase Web App (Firebase console → Project settings → Your apps)
# Also enable Google provider in Firebase console → Authentication → Sign-in method.
# Make sure localhost and your app domain are in Authorized domains.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server route handlers). Optional if using ADC.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Google Cloud clients (Document AI, etc.). Recommended: path to service account JSON.
# When set, Firebase Admin also uses this credential (see firebase-admin.ts).
GOOGLE_APPLICATION_CREDENTIALS=

# Session cookie config for /api/v1/auth/session
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_MAX_AGE_SECONDS=432000
SESSION_COOKIE_SECURE=false

# Document AI config
DOCAI_PROJECT_ID=
DOCAI_LOCATION=asia-southeast1
DOCAI_RECEIPT_PROCESSOR_ID=
DOCAI_EA_PROCESSOR_ID=

# Gemini receipt-to-relief suggestion config
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Set to "false" to use the real API route handlers.
NEXT_PUBLIC_USE_MOCK=false

# Set to "true" only for local UI/backend work without Firebase configured (never in production).
NEXT_PUBLIC_DEV_AUTH_BYPASS=false
